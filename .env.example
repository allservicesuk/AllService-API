# AllServices API — Environment Variables
# Copy this file to .env and fill in real values.
# App will refuse to boot if any required variable is missing.

# --- Region ---
# REGION identifies which region this instance serves. Values: eu, na
REGION=eu
# REGION_ROLE: primary or replica. EU is primary, NA is replica.
REGION_ROLE=primary
# PRIMARY_API_URL: required when REGION_ROLE=replica. URL of the EU primary API.
PRIMARY_API_URL=
# INTERNAL_API_SECRET: shared secret used for NA→EU internal calls (token signing).
INTERNAL_API_SECRET=

# --- App ---
NODE_ENV=development
PORT=3000
API_VERSION=1

# --- Database (Write) ---
# Points to KV2-EU PostgreSQL primary from both regions.
DATABASE_WRITE_URL=postgresql://user:pass@localhost:5432/allservices
DATABASE_WRITE_POOL_MIN=2
DATABASE_WRITE_POOL_MAX=25

# --- Database (Read) ---
# EU: same as DATABASE_WRITE_URL. NA: local read replica.
DATABASE_READ_URL=postgresql://user:pass@localhost:5432/allservices
DATABASE_READ_POOL_MIN=2
DATABASE_READ_POOL_MAX=25

# --- Database (Common) ---
DATABASE_SSL=false
DATABASE_STATEMENT_TIMEOUT=30000

# --- Redis ---
REDIS_URL=redis://:password@localhost:6379
REDIS_TLS=false
REDIS_KEY_PREFIX=as:eu:
REDIS_MAX_RETRIES=3

# --- JWT ---
# JWT_PRIVATE_KEY: required when REGION_ROLE=primary. RS256 private key (PEM).
JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY: required everywhere. RS256 public key (PEM).
JWT_PUBLIC_KEY=
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_ISSUER=allservices
JWT_AUDIENCE=allservices-api

# --- Argon2 ---
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# --- Crypto ---
CRYPTO_ENABLED=true
# CRYPTO_MASTER_KEY: 32-byte hex-encoded key (64 hex chars).
CRYPTO_MASTER_KEY=
CRYPTO_MASTER_KEY_V2=
CRYPTO_ACTIVE_VERSION=v1
CRYPTO_SESSION_TTL=3600

# --- Sentry ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_REGION=eu

# --- PostHog ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com

# --- Mail ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@allservices.cc
APP_WEB_URL=https://allservices.cc

# --- Throttle ---
THROTTLE_GLOBAL_TTL=60000
THROTTLE_GLOBAL_LIMIT=100

# --- CORS ---
ALLOWED_ORIGINS=https://allservices.cc,https://www.allservices.cc,https://dashboard.allservices.cc,https://legal.allservices.cc

# --- Logging ---
LOG_LEVEL=info

# --- Queue ---
AUDIT_ASYNC_ENABLED=false
