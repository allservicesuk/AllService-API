// Prisma schema for all models: User, Auth, Tenant, and Careers (JobPosting, Application, etc).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_WRITE_URL")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  email               String    @unique @db.VarChar(255)
  emailVerified       Boolean   @default(false)
  passwordHash        String    @db.VarChar(255)
  firstName           String?   @db.VarChar(100)
  lastName            String?   @db.VarChar(100)
  roles               String[]  @default(["user"])
  isActive            Boolean   @default(true)
  isLocked            Boolean   @default(false)
  lockReason          String?
  lockedUntil         DateTime?
  failedLoginAttempts Int       @default(0)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  passwordChangedAt   DateTime?
  mfaEnabled          Boolean   @default(false)
  mfaSecret           String?
  mfaRecoveryCodes    String[]  @default([])
  tenantId            String?   @db.Uuid
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  tenant               Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  refreshTokenFamilies RefreshTokenFamily[]

  @@index([tenantId])
  @@index([isActive])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model RefreshTokenFamily {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  currentTokenHash String
  region           String   @db.VarChar(8)
  deviceInfo       String?
  ipHash           String?
  isRevoked        Boolean  @default(false)
  revokedReason    String?
  createdAt        DateTime @default(now())
  expiresAt        DateTime
  lastUsedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([currentTokenHash])
  @@index([isRevoked])
  @@index([expiresAt])
  @@map("refresh_token_families")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @db.Uuid
  action       String   @db.VarChar(100)
  resource     String?
  detail       Json?
  ipHash       String
  userAgent    String?
  region       String   @db.VarChar(8)
  requestId    String
  previousHash String
  currentHash  String
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([requestId])
  @@map("audit_logs")
}

model Tenant {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  slug      String    @unique @db.VarChar(100)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users User[]

  @@map("tenants")
}

enum JobPostingStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum JobPostingType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum JobPostingWorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum SalaryPeriod {
  HOURLY
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  OFFER_EXTENDED
  HIRED
  REJECTED
  WITHDRAWN
}

enum MessageSenderType {
  ADMIN
  APPLICANT
}

model JobPosting {
  id          String            @id @default(uuid()) @db.Uuid
  title       String            @db.VarChar(255)
  slug        String            @unique @db.VarChar(300)
  department  String            @db.VarChar(100)
  location    String            @db.VarChar(200)
  type        JobPostingType
  workMode    JobPostingWorkMode
  description String            @db.Text
  requirements String           @db.Text
  salaryMin   Int?
  salaryMax   Int?
  salaryCurrency String?        @db.VarChar(3)
  salaryPeriod SalaryPeriod?
  cvRequired  Boolean           @default(true)
  customFields Json?
  status      JobPostingStatus  @default(DRAFT)
  closesAt    DateTime?
  publishedAt DateTime?
  createdBy   String            @db.Uuid
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  applications Application[]

  @@index([status])
  @@index([createdAt])
  @@index([closesAt])
  @@map("job_postings")
}

model Application {
  id              String            @id @default(uuid()) @db.Uuid
  jobPostingId    String            @db.Uuid
  applicantName   String            @db.VarChar(200)
  applicantEmail  String            @db.VarChar(255)
  applicantPhone  String?           @db.VarChar(30)
  phoneNormalized String?           @db.VarChar(30)
  coverLetter     String?           @db.Text
  customResponses Json?
  status          ApplicationStatus @default(DRAFT)
  emailVerified   Boolean           @default(false)
  ipHash          String            @db.VarChar(128)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  jobPosting     JobPosting                 @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  statusHistory  ApplicationStatusHistory[]
  messages       ApplicationMessage[]
  documents      ApplicationDocument[]
  applicantTokens ApplicantToken[]

  @@unique([applicantEmail, jobPostingId])
  @@index([jobPostingId])
  @@index([status])
  @@index([createdAt])
  @@map("applications")
}

model ApplicationStatusHistory {
  id            String            @id @default(uuid()) @db.Uuid
  applicationId String            @db.Uuid
  fromStatus    ApplicationStatus
  toStatus      ApplicationStatus
  notes         String?           @db.Text
  changedBy     String?           @db.VarChar(255)
  createdAt     DateTime          @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([createdAt])
  @@map("application_status_history")
}

model ApplicationMessage {
  id            String            @id @default(uuid()) @db.Uuid
  applicationId String            @db.Uuid
  senderType    MessageSenderType
  senderName    String            @db.VarChar(200)
  body          String            @db.Text
  isRead        Boolean           @default(false)
  createdAt     DateTime          @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([createdAt])
  @@map("application_messages")
}

model ApplicationDocument {
  id            String   @id @default(uuid()) @db.Uuid
  applicationId String   @db.Uuid
  filename      String   @db.VarChar(255)
  mimeType      String   @db.VarChar(100)
  sizeBytes     Int
  storagePath   String   @db.VarChar(500)
  sha256Hash    String   @db.VarChar(64)
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_documents")
}

model ApplicantToken {
  id            String   @id @default(uuid()) @db.Uuid
  applicationId String   @db.Uuid
  tokenHash     String   @unique @db.VarChar(128)
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([expiresAt])
  @@map("applicant_tokens")
}
