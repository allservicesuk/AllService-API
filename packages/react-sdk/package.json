{
  "name": "@allservices/react-sdk",
  "version": "0.1.0",
  "description": "Type-safe React SDK for the AllServices API",
  "author": "linkst",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/esm/client.d.ts",
        "default": "./dist/esm/client.js"
      },
      "require": {
        "types": "./dist/cjs/client.d.cts",
        "default": "./dist/cjs/client.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/esm/types.d.ts",
        "default": "./dist/esm/types.js"
      },
      "require": {
        "types": "./dist/cjs/types.d.cts",
        "default": "./dist/cjs/types.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/esm/testing.d.ts",
        "default": "./dist/esm/testing.js"
      },
      "require": {
        "types": "./dist/cjs/testing.d.cts",
        "default": "./dist/cjs/testing.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@tanstack/react-query": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "@tanstack/react-query": {
      "optional": false
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
